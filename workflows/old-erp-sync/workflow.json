    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "DECLARE @StartDate varchar(20) = '{{ $json.startDate }}'\nDECLARE @EndDate varchar(20) = '{{ $json.endDate }}'\n\nDECLARE @p13 VARCHAR(8000) = '';\n\nEXEC Sp_Qaa_NewMrbCount1_new1 '工序', '面积', @StartDate, @EndDate, '', '', '', '', '', '', '二厂', '报废', @p13 OUTPUT, '%', '', 'unknown';\n\nSELECT @p13 AS Result;"
      },
      "type": "n8n-nodes-base.microsoftSql",
      "typeVersion": 1.1,
      "position": [
        -256,
        -80
      ],
      "id": "5b40ee84-0844-49f8-8190-77017ea234e8",
      "name": "获取老 ERP 数据",
      "credentials": {
        "microsoftSql": {
          "id": "b6fmBvUg9kek5amd",
          "name": "Microsoft SQL account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const dataDate = $now.minus({ days: 1 }).toFormat('yyyy/MM/dd');\n\nconst inputItems = $input.all();\nconst rows = inputItems.map((item) => item.json);\n\nconst records = rows.map((row) => ({\n  fields: {\n    ProcName: String(row.ProcName ?? '').trim(),\n    ProcOrd: String(row.ProcOrd ?? ''),\n    ProcNo: String(row.ProcNo ?? ''),\n    EliArea: String(row.EliArea ?? ''),\n    EliPNL: String(row.EliPNL ?? ''),\n    ScrapArea: String(row.ScrapArea ?? ''),\n    ScrapPNL: String(row.ScrapPNL ?? ''),\n    ProdArea: String(row.ProdArea ?? ''),\n    ProdPNL: String(row.ProdPNL ?? ''),\n    BugNo: String(row.BugNo ?? '').trim(),\n    BugArea: String(row.BugArea ?? ''),\n    BugName: String(row.BugName ?? '').trim(),\n    Target: String(row.Target ?? ''),\n    zdate: dataDate\n  }\n}));\n\nreturn [{\n  json: {\n    records: records\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -48,
        -80
      ],
      "id": "523f53a0-f7a9-4cb8-a066-840ec84374d1",
      "name": "转换数据格式"
    },
