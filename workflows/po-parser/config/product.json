{
  "name": "po-parser",
  "version": "0.1.0",
  "description": "采购订单 PDF 自动解析工作流",
  "status": "development",
  "trigger": "schedule",
  "schedule": "*/1 * * * *",
  "input": {
    "type": "file",
    "format": "pdf",
    "location": "smb://fileserver/po-inbox/incoming"
  },
  "output": {
    "type": "api",
    "target": "SAP RFC",
    "mode": "staging"
  },
  "dependencies": {
    "python": ">=3.10",
    "java": ">=11",
    "opendataloader-pdf": ">=2.0.0",
    "ollama": "with qwen2.5:7b model"
  },
  "tags": ["pdf", "ocr", "sap", "purchase-order", "opendataloader"],
  "owner": "市场部",
  "created_at": "2026-03-24",
  "updated_at": "2026-03-24"
}