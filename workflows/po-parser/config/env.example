# PO Parser 环境变量配置

# 文件路径配置
PO_INBOX_PATH=/mnt/smb/po-inbox/incoming
PO_DONE_PATH=/mnt/smb/po-inbox/done
PO_ERROR_PATH=/mnt/smb/po-inbox/error
PO_REVIEW_PATH=/mnt/smb/po-inbox/review

# OpenDataLoader PDF 配置
# 安装: pip install opendataloader-pdf
# Hybrid 模式: pip install "opendataloader-pdf[hybrid]"
OPENLOADER_FORMAT=json,markdown
OPENLOADER_HYBRID=docling-fast
OPENLOADER_OCR_LANG=ch_sim,en

# Ollama 配置
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=60000

# SAP 中间服务配置
SAP_API_URL=http://sap-gateway:8080/api
SAP_API_KEY=your-api-key-here
SAP_TIMEOUT=30000

# 处理配置
SCAN_INTERVAL_MS=60000
CONFIDENCE_THRESHOLD=0.8
REVIEW_THRESHOLD=0.5
MAX_RETRY_COUNT=3

# 通知配置
NOTIFICATION_TYPE=wechat
NOTIFICATION_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx

# 日志配置
LOG_LEVEL=info
LOG_FILE=/var/log/n8n/po-parser.log