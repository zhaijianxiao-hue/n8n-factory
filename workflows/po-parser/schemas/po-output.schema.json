{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "po-output.schema.json",
  "title": "Purchase Order Output",
  "description": "采购订单解析输出结构",
  "type": "object",
  "required": ["source_file", "file_hash", "header", "items", "confidence"],
  "properties": {
    "source_file": {
      "type": "string",
      "description": "原始 PDF 文件名"
    },
    "customer_profile": {
      "type": "string",
      "description": "识别到的客户解析 profile"
    },
    "file_hash": {
      "type": "string",
      "description": "文件 MD5/SHA256 哈希值，用于幂等性检查"
    },
    "process_time": {
      "type": "string",
      "format": "date-time",
      "description": "处理时间戳"
    },
    "header": {
      "type": "object",
      "required": ["customer_name", "po_number"],
      "properties": {
        "customer_name": {
          "type": "string",
          "description": "客户名称"
        },
        "customer_code": {
          "type": "string",
          "description": "客户编码（如能映射）"
        },
        "buyer_address": {
          "type": "string",
          "description": "买方地址"
        },
        "supplier_id_at_customer": {
          "type": "string",
          "description": "客户系统中的供应商编码"
        },
        "customer_contact_person": {
          "type": "string",
          "description": "客户联系人"
        },
        "customer_contact_phone": {
          "type": "string",
          "description": "客户联系人电话"
        },
        "customer_contact_fax": {
          "type": "string",
          "description": "客户联系人传真"
        },
        "customer_contact_email": {
          "type": "string",
          "description": "客户联系人邮箱"
        },
        "supplier_name": {
          "type": "string",
          "description": "供应商名称"
        },
        "supplier_contact_person": {
          "type": "string",
          "description": "供应商联系人"
        },
        "supplier_address": {
          "type": "string",
          "description": "供应商地址"
        },
        "po_number": {
          "type": "string",
          "description": "采购订单号"
        },
        "po_date": {
          "type": "string",
          "format": "date",
          "description": "订单日期"
        },
        "currency": {
          "type": "string",
          "enum": ["CNY", "USD", "EUR", "JPY", "GBP", "HKD", "OTHER"],
          "description": "币种"
        },
        "ship_to": {
          "type": "string",
          "description": "收货地址"
        },
        "bill_to": {
          "type": "string",
          "description": "账单地址"
        },
        "contact_person": {
          "type": "string",
          "description": "联系人"
        },
        "contact_phone": {
          "type": "string",
          "description": "联系电话"
        },
        "total_amount": {
          "type": "number",
          "minimum": 0,
          "description": "总金额"
        },
        "total_qty": {
          "type": "number",
          "minimum": 0,
          "description": "总数量"
        },
        "payment_terms": {
          "type": "string",
          "description": "付款条款"
        },
        "delivery_terms": {
          "type": "string",
          "description": "交货条款"
        },
        "shipment_mode": {
          "type": "string",
          "description": "运输方式"
        },
        "delivery_tolerance_positive_pct": {
          "type": "number",
          "description": "允收正偏差百分比"
        },
        "delivery_tolerance_negative_pct": {
          "type": "number",
          "description": "允收负偏差百分比"
        },
        "delivery_tolerance_raw": {
          "type": "string",
          "description": "允差原始文本"
        },
        "blanket_order_note": {
          "type": "string",
          "description": "框架订单备注"
        },
        "production_note": {
          "type": "string",
          "description": "生产备注"
        },
        "packaging_note": {
          "type": "string",
          "description": "包装备注"
        }
      }
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["line_no", "qty"],
        "properties": {
          "line_no": {
            "type": "integer",
            "minimum": 1,
            "description": "行号"
          },
          "customer_material": {
            "type": "string",
            "description": "客户物料编码"
          },
          "sap_material": {
            "type": "string",
            "description": "SAP 物料编码（映射后）"
          },
          "material_description": {
            "type": "string",
            "description": "物料描述"
          },
          "qty": {
            "type": "number",
            "minimum": 0,
            "description": "数量"
          },
          "unit": {
            "type": "string",
            "description": "单位"
          },
          "customer_release_no": {
            "type": "string",
            "description": "客户 release/order 编号"
          },
          "customer_release_pos": {
            "type": ["string", "null"],
            "description": "客户 release position"
          },
          "price_basis_qty": {
            "type": "number",
            "minimum": 0,
            "description": "价格基准数量"
          },
          "price_basis_unit": {
            "type": "string",
            "description": "价格基准单位"
          },
          "unit_price": {
            "type": "number",
            "minimum": 0,
            "description": "单价"
          },
          "currency": {
            "type": "string",
            "description": "币种"
          },
          "amount": {
            "type": "number",
            "minimum": 0,
            "description": "行金额"
          },
          "delivery_date": {
            "type": "string",
            "format": "date",
            "description": "交货日期"
          },
          "tax_rate": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "税率(%)"
          },
          "remarks": {
            "type": "string",
            "description": "备注"
          },
          "description_raw": {
            "type": "string",
            "description": "原始描述字段"
          },
          "article_raw": {
            "type": "string",
            "description": "原始 article 字段"
          }
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "整体置信度评分 (0-1)"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "警告信息列表"
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "错误信息列表"
    },
    "raw_text": {
      "type": "string",
      "description": "PDF 原始提取文本（用于调试）"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "parser_version": {
          "type": "string"
        },
        "model_used": {
          "type": "string"
        },
        "parse_time_ms": {
          "type": "integer"
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["success", "review", "error"],
      "description": "解析状态"
    },
    "output_file": {
      "type": "string",
      "description": "落盘输出文件路径"
    }
  }
}
